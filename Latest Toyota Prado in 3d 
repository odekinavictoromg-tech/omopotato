<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>2025 Toyota Land Cruiser Prado J250 — 3D Model</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400&display=swap');

  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

  :root{
    --bg:#0a0c0f;
    --panel:#111418;
    --border:#1e2329;
    --accent:#c8a84b;
    --accent2:#e8c96a;
    --text:#c8cdd4;
    --muted:#4a5260;
  }

  body{
    background:var(--bg);
    color:var(--text);
    font-family:'DM Mono',monospace;
    height:100vh;
    overflow:hidden;
    user-select:none;
  }

  #canvas-wrap{
    position:fixed;inset:0;
    background:radial-gradient(ellipse at 50% 60%, #0d1117 0%, #060709 100%);
  }

  canvas{display:block;width:100%!important;height:100%!important;}

  /* HUD */
  #hud{
    position:fixed;inset:0;pointer-events:none;
  }

  /* Top bar */
  #topbar{
    position:absolute;top:0;left:0;right:0;
    display:flex;align-items:center;justify-content:space-between;
    padding:20px 32px 16px;
    border-bottom:1px solid var(--border);
    background:linear-gradient(to bottom,rgba(10,12,15,0.95),transparent);
  }

  #topbar h1{
    font-family:'Bebas Neue',sans-serif;
    font-size:28px;letter-spacing:3px;
    color:#fff;line-height:1;
  }
  #topbar h1 span{color:var(--accent);}

  #badge{
    font-size:10px;letter-spacing:2px;color:var(--muted);
    border:1px solid var(--border);padding:4px 10px;
    text-transform:uppercase;
  }

  /* Side info panel */
  #infobar{
    position:absolute;top:50%;right:28px;
    transform:translateY(-50%);
    width:200px;
    display:flex;flex-direction:column;gap:14px;
  }

  .spec-row{
    border-left:2px solid var(--border);
    padding:8px 14px;
    background:rgba(17,20,24,0.7);
    backdrop-filter:blur(4px);
  }
  .spec-row:hover{border-left-color:var(--accent);}
  .spec-label{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:4px;}
  .spec-val{font-size:13px;color:#fff;font-weight:400;}

  /* Controls */
  #controls{
    position:absolute;bottom:24px;left:50%;transform:translateX(-50%);
    display:flex;gap:10px;pointer-events:all;
  }
  .ctrl-btn{
    background:rgba(17,20,24,0.85);
    border:1px solid var(--border);
    color:var(--text);
    font-family:'DM Mono',monospace;
    font-size:11px;letter-spacing:1px;
    padding:10px 18px;
    cursor:pointer;
    transition:border-color .2s,color .2s;
    text-transform:uppercase;
  }
  .ctrl-btn:hover,.ctrl-btn.active{
    border-color:var(--accent);color:var(--accent);
  }

  /* Hint */
  #hint{
    position:absolute;bottom:70px;left:50%;transform:translateX(-50%);
    font-size:10px;letter-spacing:2px;color:var(--muted);
    text-align:center;white-space:nowrap;
  }

  /* Corner cross-hairs */
  .corner{position:absolute;width:18px;height:18px;}
  .corner::before,.corner::after{content:'';position:absolute;background:var(--accent);opacity:.5;}
  .corner::before{width:100%;height:1px;top:0;left:0;}
  .corner::after{width:1px;height:100%;top:0;left:0;}
  .corner.tr{top:12px;right:12px;transform:rotate(90deg);}
  .corner.bl{bottom:12px;left:12px;transform:rotate(270deg);}
  .corner.br{bottom:12px;right:12px;transform:rotate(180deg);}
  .corner.tl{top:12px;left:12px;}

  /* Loading */
  #loading{
    position:fixed;inset:0;background:var(--bg);
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    z-index:100;transition:opacity .6s;
  }
  #loading h2{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:6px;color:var(--accent);margin-bottom:16px;}
  #loading p{font-size:11px;letter-spacing:3px;color:var(--muted);}
  #load-bar{width:220px;height:1px;background:var(--border);margin-top:20px;overflow:hidden;}
  #load-fill{height:100%;background:var(--accent);width:0%;transition:width .4s;}
</style>
</head>
<body>

<div id="loading">
  <h2>PRADO J250</h2>
  <p>BUILDING 3D MODEL</p>
  <div id="load-bar"><div id="load-fill"></div></div>
</div>

<div id="canvas-wrap"><canvas id="c"></canvas></div>

<div id="hud">
  <div class="corner tl"></div>
  <div class="corner tr"></div>
  <div class="corner bl"></div>
  <div class="corner br"></div>

  <div id="topbar">
    <div>
      <h1>TOYOTA LAND CRUISER <span>PRADO</span></h1>
      <div style="font-size:10px;letter-spacing:3px;color:var(--muted);margin-top:4px;">J250 SERIES · 2024–2025</div>
    </div>
    <div id="badge">3D INTERACTIVE MODEL</div>
  </div>

  <div id="infobar">
    <div class="spec-row"><div class="spec-label">Platform</div><div class="spec-val">TNGA-F</div></div>
    <div class="spec-row"><div class="spec-label">Engine</div><div class="spec-val">2.4L Hybrid</div></div>
    <div class="spec-row"><div class="spec-label">Output</div><div class="spec-val">326 hp</div></div>
    <div class="spec-row"><div class="spec-label">Torque</div><div class="spec-val">465 lb-ft</div></div>
    <div class="spec-row"><div class="spec-label">Drive</div><div class="spec-val">Full-time 4WD</div></div>
    <div class="spec-row"><div class="spec-label">Length</div><div class="spec-val">193.7 in</div></div>
    <div class="spec-row"><div class="spec-label">Clearance</div><div class="spec-val">8.7 in</div></div>
  </div>

  <div id="hint">DRAG TO ROTATE · SCROLL TO ZOOM · RIGHT-DRAG TO PAN</div>

  <div id="controls">
    <button class="ctrl-btn" onclick="setColor(0x1a2540)">OCEAN BLUE</button>
    <button class="ctrl-btn active" onclick="setColor(0x2c2c2e)">GRAPHITE</button>
    <button class="ctrl-btn" onclick="setColor(0xf5f0e8)">PEARL WHITE</button>
    <button class="ctrl-btn" onclick="setColor(0x8b1a1a)">HERITAGE RED</button>
    <button class="ctrl-btn" onclick="resetCamera()">RESET VIEW</button>
  </div>
</div>

<script type="importmap">
{
  "imports": {
    "three": "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.module.js"
  }
}
</script>

<script type="module">
import * as THREE from 'three';

/* ── Loading bar ── */
const fill = document.getElementById('load-fill');
const loading = document.getElementById('loading');
let prog = 0;
const tick = setInterval(()=>{prog=Math.min(prog+Math.random()*18,90);fill.style.width=prog+'%';},120);

/* ── Scene ── */
const canvas = document.getElementById('c');
const renderer = new THREE.WebGLRenderer({canvas,antialias:true,alpha:false});
renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.outputEncoding = THREE.sRGBEncoding;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x060709, 0.038);

const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 200);
camera.position.set(6, 2.6, 6);
camera.lookAt(0, 0.4, 0);

/* ── Resize ── */
function resize(){
  const w=window.innerWidth, h=window.innerHeight;
  renderer.setSize(w,h);
  camera.aspect=w/h;
  camera.updateProjectionMatrix();
}
resize();
window.addEventListener('resize',resize);

/* ── Lights ── */
const ambient = new THREE.AmbientLight(0xffffff, 0.35);
scene.add(ambient);

const sun = new THREE.DirectionalLight(0xfff5e0, 2.8);
sun.position.set(8, 12, 6);
sun.castShadow = true;
sun.shadow.mapSize.set(2048, 2048);
sun.shadow.camera.near = 0.5;
sun.shadow.camera.far = 60;
sun.shadow.camera.left = -10;
sun.shadow.camera.right = 10;
sun.shadow.camera.top = 10;
sun.shadow.camera.bottom = -10;
sun.shadow.bias = -0.001;
scene.add(sun);

const fill1 = new THREE.DirectionalLight(0xadc8ff, 0.9);
fill1.position.set(-6, 4, -4);
scene.add(fill1);

const rim = new THREE.DirectionalLight(0xfff0c0, 1.1);
rim.position.set(-3, 2, -8);
scene.add(rim);

const ground_bounce = new THREE.HemisphereLight(0x404858, 0x202830, 0.5);
scene.add(ground_bounce);

/* ── Materials ── */
let bodyColor = 0x2c2c2e;
let bodyMat = makeMat(bodyColor);

function makeMat(hex){
  return new THREE.MeshStandardMaterial({
    color: hex,
    metalness: 0.75,
    roughness: 0.28,
    envMapIntensity: 1.0
  });
}

const darkMat  = new THREE.MeshStandardMaterial({color:0x101214,metalness:0.3,roughness:0.7});
const blackMat = new THREE.MeshStandardMaterial({color:0x080a0b,metalness:0.1,roughness:0.9});
const chromeMat= new THREE.MeshStandardMaterial({color:0xd0d8e0,metalness:0.95,roughness:0.07});
const glassMat = new THREE.MeshStandardMaterial({color:0x8ab0c8,metalness:0.1,roughness:0.05,transparent:true,opacity:0.32});
const rubberMat= new THREE.MeshStandardMaterial({color:0x111315,metalness:0.0,roughness:0.95});
const tireMat  = new THREE.MeshStandardMaterial({color:0x181a1c,metalness:0.0,roughness:0.9});
const wheelMat = new THREE.MeshStandardMaterial({color:0xb8bfc8,metalness:0.9,roughness:0.12});
const redMat   = new THREE.MeshStandardMaterial({color:0xcc1a1a,metalness:0.4,roughness:0.3,emissive:0x440000});
const amberMat = new THREE.MeshStandardMaterial({color:0xffa020,metalness:0.2,roughness:0.3,emissive:0x331000});
const underbodyMat=new THREE.MeshStandardMaterial({color:0x1a1c1e,metalness:0.3,roughness:0.8});
const skidMat  = new THREE.MeshStandardMaterial({color:0x2a2e32,metalness:0.6,roughness:0.5});

/* ── Geometry helpers ── */
function box(w,h,d,mat,x=0,y=0,z=0,rx=0,ry=0,rz=0){
  const m=new THREE.Mesh(new THREE.BoxGeometry(w,h,d),mat);
  m.position.set(x,y,z); m.rotation.set(rx,ry,rz);
  m.castShadow=true; m.receiveShadow=true;
  return m;
}
function cyl(rt,rb,h,seg,mat,x=0,y=0,z=0,rx=0,ry=0,rz=0){
  const m=new THREE.Mesh(new THREE.CylinderGeometry(rt,rb,h,seg),mat);
  m.position.set(x,y,z); m.rotation.set(rx,ry,rz);
  m.castShadow=true; m.receiveShadow=true;
  return m;
}
function sphere(r,seg,mat,x=0,y=0,z=0){
  const m=new THREE.Mesh(new THREE.SphereGeometry(r,seg,seg),mat);
  m.position.set(x,y,z); m.castShadow=true;
  return m;
}
function torus(r,tube,rs,ts,mat,x=0,y=0,z=0){
  const m=new THREE.Mesh(new THREE.TorusGeometry(r,tube,rs,ts),mat);
  m.position.set(x,y,z); m.castShadow=true;
  return m;
}

/* ── Build Prado J250 ── */
const car = new THREE.Group();

// ===== UNDERBODY / CHASSIS =====
const chassis = box(4.6,0.18,1.95,underbodyMat, 0,0.42,0);
car.add(chassis);

// Skid plates (front + rear)
car.add(box(1.7,0.12,1.9, skidMat, -1.5,0.36,0));  // front skid
car.add(box(1.2,0.12,1.9, skidMat,  1.6,0.36,0));  // rear skid

// ===== BODY — LOWER SECTION (boxy slab sides) =====
// Main lower body
const lowerBody = box(4.72,0.65,2.0, bodyMat, 0,0.87,0);
car.add(lowerBody);

// Cladding / lower trim strips (plastic)
car.add(box(4.75,0.20,2.02, darkMat, 0,0.62,0));     // rocker panel
car.add(box(1.60,0.22,2.04, darkMat, -1.55,0.62,0)); // front lower cladding
car.add(box(1.30,0.22,2.04, darkMat,  1.65,0.62,0)); // rear lower cladding

// ===== BODY — UPPER / CABIN =====
// Wide flat cabin — J250 signature boxy shape
const cabin = box(3.1,0.72,1.92, bodyMat, 0.12,1.57,0);
car.add(cabin);

// Roof (slightly narrower)
const roof = box(2.85,0.12,1.88, bodyMat, 0.12,1.94,0);
car.add(roof);

// Roof rack
const rackBar = ()=>{
  const g=new THREE.Group();
  g.add(box(2.6,0.04,0.04,chromeMat));
  return g;
};
const rack = new THREE.Group();
rack.position.set(0.12,2.04,0);
[-0.78,0,0.78].forEach(z=>{
  const b=box(2.6,0.04,0.04,chromeMat,0,0,z);
  rack.add(b);
});
[-1.0,-0.3,0.3,1.0].forEach(x=>{
  const b=box(0.04,0.04,1.6,chromeMat,x,0,0);
  rack.add(b);
});
// Corner feet
[[-1.02,-0.79],[-1.02,0.79],[1.02,-0.79],[1.02,0.79]].forEach(([x,z])=>{
  rack.add(cyl(0.025,0.025,0.12,8,chromeMat,x,-0.08,z, 0,0,0));
});
car.add(rack);

// A-pillars
car.add(box(0.08,0.8,0.06, darkMat, -1.4,1.56,-0.88));
car.add(box(0.08,0.8,0.06, darkMat, -1.4,1.56, 0.88));

// B-pillars
car.add(box(0.07,0.75,0.05, darkMat,  0.2,1.56,-0.93));
car.add(box(0.07,0.75,0.05, darkMat,  0.2,1.56, 0.93));

// C-pillars
car.add(box(0.07,0.75,0.05, darkMat,  1.3,1.56,-0.93));
car.add(box(0.07,0.75,0.05, darkMat,  1.3,1.56, 0.93));

// ===== HOOD (flat angular) =====
const hoodGeo = new THREE.BufferGeometry();
const hv = new Float32Array([
  // flat top with front lip angle
  -1.55,1.22,-0.97,  -1.55,1.22,0.97,  -2.35,0.82,-0.97,  -2.35,0.82,0.97,
]);
const hi = new Uint16Array([0,2,1, 1,2,3]);
hoodGeo.setAttribute('position',new THREE.BufferAttribute(hv,3));
hoodGeo.setIndex(new THREE.BufferAttribute(hi,1));
hoodGeo.computeVertexNormals();
const hoodMesh = new THREE.Mesh(hoodGeo, bodyMat);
hoodMesh.castShadow=true;
car.add(hoodMesh);

// Hood flat centre
car.add(box(0.82,0.02,1.80, bodyMat, -1.95,1.02,0));
car.add(box(0.55,0.03,1.78, bodyMat, -1.58,1.22,0));

// ===== FRONT FACE =====
// Upper grille surround
car.add(box(0.08,0.46,2.0, bodyMat, -2.34,1.0,0));       // upper front face

// Grille mesh (dark honeycomb look via thin strips)
const grilleBase = box(0.05,0.30,1.72, blackMat, -2.38,0.96,0);
car.add(grilleBase);
for(let z=-0.72;z<=0.72;z+=0.18){
  car.add(box(0.06,0.30,0.03, chromeMat, -2.38,0.96,z));
}
for(let y=0.82;y<=1.10;y+=0.12){
  car.add(box(0.06,0.025,1.74, chromeMat, -2.38,y,0));
}

// Toyota badge area (centre of grille)
car.add(cyl(0.11,0.11,0.04,16,chromeMat,-2.4,0.96,0, Math.PI/2,0,0));

// Grille chrome surround
car.add(box(0.04,0.34,1.76, chromeMat, -2.40,0.96,0));         // top bar
car.add(box(0.06,0.06,1.76, chromeMat, -2.38,1.12,0));         // chrome top strip

// Bumper
const fBumper = box(0.22,0.38,2.0, darkMat, -2.4,0.58,0);
car.add(fBumper);
// Bumper skid plate
car.add(box(0.12,0.10,1.9, skidMat, -2.44,0.42,0));
// Tow hook
car.add(box(0.20,0.06,0.06,chromeMat,-2.52,0.48,-0.55));

// ===== HEADLIGHTS — J250 rectangular signature =====
// Left headlight cluster
const hlGroup = (side)=>{
  const sg = new THREE.Group();
  // DRL bar (thin horizontal strip)
  sg.add(box(0.06,0.06,0.56, new THREE.MeshStandardMaterial({color:0xffffff,emissive:0xaaccff,emissiveIntensity:0.6,metalness:0.1,roughness:0.1}), -2.31,1.10,0));
  // Main lamp housing
  sg.add(box(0.10,0.22,0.58, new THREE.MeshStandardMaterial({color:0xd0e8ff,metalness:0.3,roughness:0.05,transparent:true,opacity:0.7,emissive:0x203040,emissiveIntensity:0.3}), -2.33,0.96,0));
  // Inner chrome surround
  sg.add(box(0.06,0.26,0.62, chromeMat, -2.36,0.96,0));
  // Corner amber indicator
  sg.add(box(0.07,0.10,0.14, amberMat, -2.36,0.82, 0.24));
  sg.position.z = side * 0.7;
  return sg;
};
car.add(hlGroup(1));
car.add(hlGroup(-1));

// ===== REAR FACE =====
// Tail gate (vertical)
car.add(box(0.08,0.88,1.96, bodyMat, 2.32,1.30,0));

// Tail light clusters — J250 L-shaped
const tlGroup = (side)=>{
  const g=new THREE.Group();
  // Vertical bar
  g.add(box(0.06,0.70,0.12, redMat, 2.30,1.30,0));
  // Horizontal bar at top
  g.add(box(0.06,0.12,0.52, redMat, 2.30,1.62,0.22));
  // Chrome surround
  g.add(box(0.04,0.74,0.14, chromeMat, 2.32,1.30,0));
  // Reverse light
  g.add(box(0.05,0.16,0.14, new THREE.MeshStandardMaterial({color:0xffffff,emissive:0xffffff,emissiveIntensity:0.4}), 2.30,0.96,0));
  g.position.z = side * 0.82;
  return g;
};
car.add(tlGroup(1));
car.add(tlGroup(-1));

// Rear bumper
car.add(box(0.20,0.38,2.0, darkMat, 2.40,0.60,0));
car.add(box(0.12,0.10,1.9, skidMat, 2.44,0.42,0)); // rear skid plate
// Number plate recess
car.add(box(0.04,0.18,0.52, blackMat, 2.35,0.70,0));
// Tow bar
car.add(cyl(0.045,0.045,0.28,8,chromeMat, 2.54,0.46,0, 0,0,Math.PI/2));

// ===== SIDE DETAILS =====
// Front door
car.add(box(1.10,0.66,0.04, bodyMat, -0.6,1.22,-1.00));
car.add(box(1.10,0.66,0.04, bodyMat, -0.6,1.22,  1.00));
// Rear door
car.add(box(1.08,0.66,0.04, bodyMat,  0.72,1.22,-1.00));
car.add(box(1.08,0.66,0.04, bodyMat,  0.72,1.22,  1.00));

// Door handles
[-0.55,0.78].forEach(x=>{
  [-1.03,1.03].forEach(z=>{
    car.add(box(0.22,0.04,0.03, chromeMat, x,1.22,z));
  });
});

// Side mirrors
const mirror=(side)=>{
  const g=new THREE.Group();
  g.add(box(0.08,0.14,0.22,darkMat));       // housing
  g.add(box(0.02,0.11,0.18,blackMat,0.05,0,0)); // glass
  g.add(box(0.04,0.03,0.16,darkMat,-0.06,-0.09,0)); // arm
  g.position.set(-1.58,1.48,side*1.06);
  return g;
};
car.add(mirror(1));
car.add(mirror(-1));

// Side cladding trim lines
[-1.01,1.01].forEach(z=>{
  car.add(box(4.5,0.04,0.015, darkMat, 0,0.80,z));   // body line
  car.add(box(4.5,0.03,0.015, chromeMat, 0,1.40,z));  // upper character line
});

// Fuel cap
car.add(cyl(0.10,0.10,0.025,16,darkMat, 0.60,1.22,-1.01, 0,0,Math.PI/2));

// ===== WINDOWS =====
// Windshield (slight rake)
const wsGeo=new THREE.BufferGeometry();
const wsv=new Float32Array([
  -1.55,1.96,-0.88,  -1.55,1.96,0.88,
  -1.12,1.22,-0.88,  -1.12,1.22,0.88
]);
const wsi=new Uint16Array([0,2,1,1,2,3]);
wsGeo.setAttribute('position',new THREE.BufferAttribute(wsv,3));
wsGeo.setIndex(new THREE.BufferAttribute(wsi,1));
wsGeo.computeVertexNormals();
car.add(new THREE.Mesh(wsGeo,glassMat));

// Rear window
const rwGeo=new THREE.BufferGeometry();
const rwv=new Float32Array([
  1.68,1.92,-0.86,  1.68,1.92,0.86,
  1.95,1.22,-0.86,  1.95,1.22,0.86
]);
const rwi=new Uint16Array([0,1,2,1,3,2]);
rwGeo.setAttribute('position',new THREE.BufferAttribute(rwv,3));
rwGeo.setIndex(new THREE.BufferAttribute(rwi,1));
rwGeo.computeVertexNormals();
car.add(new THREE.Mesh(rwGeo,glassMat));

// Side windows (front + rear)
[-0.60,0.72].forEach((x,i)=>{
  [-1.0,1.0].forEach(z=>{
    const sg=new THREE.Mesh(new THREE.BoxGeometry(0.95,0.44,0.02),glassMat);
    sg.position.set(x,1.56,z); car.add(sg);
  });
});
// Quarter window
[-1.0,1.0].forEach(z=>{
  const qg=new THREE.Mesh(new THREE.BoxGeometry(0.32,0.32,0.02),glassMat);
  qg.position.set(1.50,1.55,z); car.add(qg);
});

// ===== SPARE TYRE on tailgate =====
const spareGroup=new THREE.Group();
spareGroup.add(torus(0.34,0.12,12,24,tireMat,0,0,0));
spareGroup.add(cyl(0.21,0.21,0.14,16,wheelMat,0,0,0));
spareGroup.add(cyl(0.04,0.04,0.16,8,chromeMat,0,0,0));
// Wheel spokes
for(let i=0;i<5;i++){
  const angle=i*(Math.PI*2/5);
  const sm=new THREE.Mesh(new THREE.BoxGeometry(0.04,0.04,0.30),wheelMat);
  sm.position.set(Math.cos(angle)*0.11,Math.sin(angle)*0.11,0);
  sm.rotation.z=angle;
  spareGroup.add(sm);
}
spareGroup.rotation.y=Math.PI/2;
spareGroup.position.set(2.40,1.28,0);
car.add(spareGroup);
// Spare tyre cover
car.add(cyl(0.38,0.38,0.05,24,darkMat, 2.43,1.28,0, 0,0,Math.PI/2));

// ===== WHEELS (x4) =====
const wheelPositions=[
  [-1.48,0.38,-1.00],[-1.48,0.38, 1.00],
  [ 1.32,0.38,-1.00],[ 1.32,0.38, 1.00]
];

const wheels=[];
wheelPositions.forEach(([x,y,z])=>{
  const wg=new THREE.Group();

  // Tyre
  const tyreMesh=torus(0.34,0.13,16,32,tireMat);
  tyreMesh.rotation.y=Math.PI/2;
  wg.add(tyreMesh);

  // Sidewall detail
  const sw=new THREE.Mesh(new THREE.CylinderGeometry(0.36,0.36,0.04,32),rubberMat);
  sw.rotation.z=Math.PI/2;
  sw.position.x=z<0?-0.075:0.075;
  wg.add(sw);

  // Rim
  const rim=new THREE.Mesh(new THREE.CylinderGeometry(0.215,0.215,0.20,32),wheelMat);
  rim.rotation.z=Math.PI/2;
  wg.add(rim);

  // Centre cap
  const cap=new THREE.Mesh(new THREE.CylinderGeometry(0.06,0.06,0.22,16),chromeMat);
  cap.rotation.z=Math.PI/2;
  wg.add(cap);

  // Spokes (5-spoke design)
  for(let i=0;i<5;i++){
    const angle=i*(Math.PI*2/5);
    const spoke=new THREE.Mesh(new THREE.BoxGeometry(0.20,0.042,0.042),wheelMat);
    spoke.position.set(0, Math.cos(angle)*0.115, Math.sin(angle)*0.115);
    spoke.rotation.x=angle;
    wg.add(spoke);
    // Outer spoke end
    const nub=new THREE.Mesh(new THREE.BoxGeometry(0.20,0.045,0.045),wheelMat);
    nub.position.set(0, Math.cos(angle)*0.16, Math.sin(angle)*0.16);
    nub.rotation.x=angle;
    wg.add(nub);
  }

  // Brake disc glimpse
  const disc=new THREE.Mesh(new THREE.CylinderGeometry(0.17,0.17,0.02,24),
    new THREE.MeshStandardMaterial({color:0x4a4e52,metalness:0.8,roughness:0.4}));
  disc.rotation.z=Math.PI/2;
  wg.add(disc);

  wg.position.set(x,y,z);
  wg.castShadow=true;
  wg.receiveShadow=true;
  car.add(wg);
  wheels.push(wg);
});

// Wheel arches (inner)
wheelPositions.forEach(([x,y,z])=>{
  const arch=new THREE.Mesh(new THREE.CylinderGeometry(0.44,0.44,0.22,24,1,false,0,Math.PI),blackMat);
  arch.rotation.set(0,z<0?0:Math.PI,0);
  arch.position.set(x,y+0.06,z);
  car.add(arch);
});

// ===== GROUND =====
const ground=new THREE.Mesh(
  new THREE.PlaneGeometry(30,30),
  new THREE.MeshStandardMaterial({color:0x0d1014,metalness:0.0,roughness:1.0,
    // subtle grid
  })
);
ground.rotation.x=-Math.PI/2;
ground.receiveShadow=true;
scene.add(ground);

// Grid lines on ground
const grid=new THREE.GridHelper(20,40,0x1a2030,0x111820);
grid.position.y=0.001;
scene.add(grid);

// ===== ENVIRONMENT — tone sphere =====
const envGeo=new THREE.SphereGeometry(80,16,16);
const envMat=new THREE.MeshBasicMaterial({
  color:0x08090c,side:THREE.BackSide
});
scene.add(new THREE.Mesh(envGeo,envMat));

car.position.y=0.02;
scene.add(car);

/* ── Orbit Controls (manual) ── */
let isDragging=false, isRightDrag=false;
let prevX=0, prevY=0;
let theta=0.65, phi=0.38, radius=10.5;
let targetTheta=theta, targetPhi=phi, targetRadius=radius;
let panX=0, panY=0, targetPanX=0, targetPanY=0;
const TARGET=new THREE.Vector3(0,0.5,0);

function updateCamera(){
  const cx=TARGET.x+panX+radius*Math.sin(phi)*Math.sin(theta);
  const cy=TARGET.y+panY+radius*Math.cos(phi);
  const cz=TARGET.z+radius*Math.sin(phi)*Math.cos(theta);
  camera.position.set(cx,cy,cz);
  camera.lookAt(TARGET.x+panX, TARGET.y+panY, TARGET.z);
}

canvas.addEventListener('mousedown',e=>{
  isDragging=true; isRightDrag=(e.button===2);
  prevX=e.clientX; prevY=e.clientY;
});
canvas.addEventListener('contextmenu',e=>e.preventDefault());
window.addEventListener('mousemove',e=>{
  if(!isDragging)return;
  const dx=e.clientX-prevX, dy=e.clientY-prevY;
  if(isRightDrag){
    targetPanX-=dx*0.008; targetPanY+=dy*0.008;
  } else {
    targetTheta-=dx*0.006; targetPhi=Math.max(0.1,Math.min(1.4,targetPhi+dy*0.005));
  }
  prevX=e.clientX; prevY=e.clientY;
});
window.addEventListener('mouseup',()=>isDragging=false);
canvas.addEventListener('wheel',e=>{
  targetRadius=Math.max(3.5,Math.min(22,targetRadius+e.deltaY*0.012));
},{passive:true});

// Touch
let lastTouchDist=0,touchCount=0;
canvas.addEventListener('touchstart',e=>{
  touchCount=e.touches.length;
  if(e.touches.length===1){isDragging=true;prevX=e.touches[0].clientX;prevY=e.touches[0].clientY;}
  if(e.touches.length===2){
    lastTouchDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
  }
},{passive:true});
canvas.addEventListener('touchmove',e=>{
  if(e.touches.length===1&&isDragging){
    const dx=e.touches[0].clientX-prevX, dy=e.touches[0].clientY-prevY;
    targetTheta-=dx*0.007; targetPhi=Math.max(0.1,Math.min(1.4,targetPhi+dy*0.006));
    prevX=e.touches[0].clientX; prevY=e.touches[0].clientY;
  }
  if(e.touches.length===2){
    const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
    targetRadius=Math.max(3.5,Math.min(22,targetRadius-(d-lastTouchDist)*0.04));
    lastTouchDist=d;
  }
},{passive:true});
canvas.addEventListener('touchend',()=>{isDragging=false;},{passive:true});

window.setColor=function(hex){
  bodyMat.color.setHex(hex);
  bodyMat.needsUpdate=true;
  document.querySelectorAll('.ctrl-btn').forEach(b=>b.classList.remove('active'));
  event.target.classList.add('active');
};

window.resetCamera=function(){
  targetTheta=0.65; targetPhi=0.38; targetRadius=10.5;
  targetPanX=0; targetPanY=0;
};

/* ── Animate ── */
const clock=new THREE.Clock();
let autoRotate=true;

function animate(){
  requestAnimationFrame(animate);
  const t=clock.getElapsedTime();

  // Auto-rotate when idle
  if(!isDragging) targetTheta+=0.003;

  // Lerp camera
  theta+=(targetTheta-theta)*0.06;
  phi+=(targetPhi-phi)*0.06;
  radius+=(targetRadius-radius)*0.07;
  panX+=(targetPanX-panX)*0.07;
  panY+=(targetPanY-panY)*0.07;
  updateCamera();

  // Wheel roll (cosmetic)
  wheels.forEach(w=>{
    w.rotation.x+=0.008;
  });

  // Subtle body float
  car.position.y=0.02+Math.sin(t*0.8)*0.012;

  renderer.render(scene,camera);
}

// Finish loading
clearInterval(tick);
fill.style.width='100%';
setTimeout(()=>{
  loading.style.opacity='0';
  setTimeout(()=>loading.style.display='none',600);
  animate();
},500);
</script>
